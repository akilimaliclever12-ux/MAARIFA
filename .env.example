# --- Supabase (from your Supabase project: Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used for admin/moderation actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
# Used for absolute URLs (Open Graph, WhatsApp share, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (Resend) — optional at first; Supabase sends auth emails by default ---
# Leave RESEND_API_KEY empty to disable custom emails (approval/rejection); the
# app no-ops gracefully. Set EMAIL_FROM to a verified-domain address in prod.
RESEND_API_KEY=
EMAIL_FROM=Maarifa <onboarding@resend.dev>
# Address that gets notified when a new publication is submitted for moderation.
ADMIN_NOTIFY_EMAIL=

# Optional salt for hashing visitor IPs in download/view logs (set any random string).
IP_HASH_SALT=
