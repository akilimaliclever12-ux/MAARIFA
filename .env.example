# --- Supabase (from your Supabase project: Settings > API) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER expose to the browser. Used for admin/moderation actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- App ---
# Used for absolute URLs (Open Graph, WhatsApp share, sitemap).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Email (Resend) — optional at first; Supabase sends auth emails by default ---
RESEND_API_KEY=

# Optional salt for hashing visitor IPs in download/view logs (set any random string).
IP_HASH_SALT=
